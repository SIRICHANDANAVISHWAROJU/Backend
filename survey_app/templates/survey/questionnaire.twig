{% extends "layouts/base.twig" %}

{% block title %}{{ survey.topic }} — Survey{% endblock %}

{% block navbar %}
<nav class="navbar">
    <div class="container">
        <a href="/" class="navbar-brand">Survey<span>Hub</span></a>
    </div>
</nav>
{% endblock %}

{% block extra_css %}
<style>
    .survey-header {
        text-align: center;
        padding: 48px 0 32px;
    }
    .survey-header h1 {
        font-family: 'DM Serif Display', serif;
        font-size: 2.2rem;
        letter-spacing: -0.5px;
        margin-bottom: 8px;
    }
    .survey-header p {
        color: var(--text-dim);
    }

    .question-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 28px;
        margin-bottom: 20px;
        transition: border-color 0.3s;
    }
    .question-card:hover { border-color: #3d4260; }

    .q-number {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; border-radius: 8px;
        background: rgba(108,92,231,0.15); color: var(--accent-light);
        font-size: 0.85rem; font-weight: 700; margin-bottom: 14px;
    }
    .q-text {
        font-size: 1.05rem; font-weight: 500; margin-bottom: 18px;
        line-height: 1.5;
    }

    .options-list { display: grid; gap: 10px; }

    .option-label {
        display: flex; align-items: center; gap: 14px;
        padding: 14px 18px; border-radius: 10px;
        border: 1px solid var(--border); background: var(--surface-2);
        cursor: pointer; transition: all 0.2s; font-size: 0.95rem;
    }
    .option-label:hover {
        border-color: var(--accent); background: rgba(108,92,231,0.08);
    }
    .option-label input[type="radio"] { display: none; }
    .option-label input[type="radio"]:checked + .option-radio {
        border-color: var(--accent); background: var(--accent);
    }
    .option-label input[type="radio"]:checked + .option-radio::after {
        content: ''; display: block; width: 8px; height: 8px;
        border-radius: 50%; background: #fff;
    }
    .option-radio {
        width: 22px; height: 22px; border-radius: 50%;
        border: 2px solid var(--border); flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
    }
    input[type="radio"]:checked ~ .option-text { color: var(--text); font-weight: 500; }
    .option-text { color: var(--text-dim); transition: color 0.2s; }

    .submit-area {
        text-align: center;
        padding: 20px 0 60px;
    }
    .submit-area .btn { padding: 16px 48px; font-size: 1.05rem; }

    .progress-bar {
        position: fixed; top: 0; left: 0; height: 3px;
        background: var(--accent); z-index: 200;
        transition: width 0.3s;
    }
</style>
{% endblock %}

{% block content %}
<div class="progress-bar" id="progressBar"></div>

<div class="container-sm">
    <div class="survey-header">
        <h1>{{ survey.topic }}</h1>
        <p>{{ survey.questions | length }} questions &middot; Anonymous submission</p>
    </div>

    <form method="POST" action="/survey/{{ survey.slug }}/submit" id="surveyForm">
        {% for question in survey.questions %}
        <div class="question-card" data-question="{{ loop.index }}">
            <div class="q-number">{{ loop.index }}</div>
            <div class="q-text">{{ question.question_text }}</div>
            <div class="options-list">
                {% for option in question.options %}
                <label class="option-label">
                    <input type="radio" name="answers[{{ question.id }}]" value="{{ option.id }}" required>
                    <span class="option-radio"></span>
                    <span class="option-text">{{ option.option_text }}</span>
                </label>
                {% endfor %}
            </div>
        </div>
        {% endfor %}

        <div class="submit-area">
            <button type="submit" class="btn btn-primary" id="submitBtn">Submit Responses</button>
            <p class="text-dim mt-2" style="font-size:0.85rem;">Your responses are completely anonymous.</p>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
    // Progress bar
    const totalQuestions = {{ survey.questions | length }};
    const progressBar = document.getElementById('progressBar');

    function updateProgress() {
        const answered = document.querySelectorAll('input[type="radio"]:checked').length;
        const pct = (answered / totalQuestions) * 100;
        progressBar.style.width = pct + '%';
    }

    document.querySelectorAll('input[type="radio"]').forEach(function(radio) {
        radio.addEventListener('change', updateProgress);
    });

    // Validate all answered before submit
    document.getElementById('surveyForm').addEventListener('submit', function(e) {
        const answered = document.querySelectorAll('input[type="radio"]:checked').length;
        if (answered < totalQuestions) {
            e.preventDefault();
            alert('Please answer all ' + totalQuestions + ' questions before submitting.');

            // Scroll to first unanswered
            const cards = document.querySelectorAll('.question-card');
            for (let card of cards) {
                const qNum = card.dataset.question;
                const checked = card.querySelector('input[type="radio"]:checked');
                if (!checked) {
                    card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    card.style.borderColor = 'var(--danger)';
                    setTimeout(() => card.style.borderColor = '', 2000);
                    break;
                }
            }
        }
    });
</script>
{% endblock %}
